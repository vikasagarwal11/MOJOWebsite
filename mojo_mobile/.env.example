# Development environment values for mojo_mobile.
# Default file loaded when APP_ENV is not provided.

# Stripe publishable keys
# In dev, app uses STRIPE_PUBLISHABLE_KEY_TEST first.
STRIPE_PUBLISHABLE_KEY_TEST=
STRIPE_PUBLISHABLE_KEY_LIVE=
# Legacy fallback (optional)
STRIPE_PUBLISHABLE_KEY=

# Zelle manual payment target shown in app for zelle events
ZELLE_RECIPIENT_EMAIL=
ZELLE_RECIPIENT_PHONE=

# Optional drawer shortcuts
MOJO_INSTAGRAM_URL=https://instagram.com/yourhandle
MOJO_FACEBOOK_URL=https://facebook.com/yourpage

# Cloudinary unsigned upload preset only
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=


# Google Maps API Key for Geo Event Discovery
GOOGLE_MAPS_API_KEY=AIzaSyCUCw31tvQAdhODTqSddJVqKZXqzaDB6gQ
