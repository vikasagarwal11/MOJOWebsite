# Copy to `.env` in this folder (gitignored). Values are bundled as Flutter assets for runtime.

# Cloudinary: unsigned upload preset only — never put API secret in the app.
# In Cloudinary Console: Settings → Upload → Add upload preset → Signing mode: Unsigned;
# restrict folder, max size, and allowed formats.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_UPLOAD_PRESET=

# Stripe publishable key (test or live) from Dashboard → Developers → API keys
STRIPE_PUBLISHABLE_KEY=
